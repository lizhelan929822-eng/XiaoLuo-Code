{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "lib": ["ES2023", "dom"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node", "bun"],
    "typeRoots": ["node_modules/@types"],
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "*": ["*", "src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/index.ts",
    "src/QueryEngine.ts",
    "src/Task.ts",
    "src/Tool.ts",
    "src/commands.ts",
    "src/context.ts",
    "src/cost-tracker.ts",
    "src/costHook.ts",
    "src/dialogLaunchers.tsx",
    "src/history.ts",
    "src/ink.ts",
    "src/interactiveHelpers.tsx",
    "src/projectOnboardingState.ts",
    "src/query.ts",
    "src/replLauncher.tsx",
    "src/setup.ts",
    "src/tasks.ts",
    "src/tools.ts",
    "src/gateway/**/*"
  ]
}