{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "lib": ["ES2023", "dom"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node", "bun"],
    "typeRoots": ["node_modules/@types"],
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "*": ["*", "src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/index.ts",
    "src/QueryEngine.ts",
    "src/Task.ts",
    "src/Tool.ts",
    "src/commands.ts",
    "src/context.ts",
    "src/cost-tracker.ts",
    "src/costHook.ts",
    "src/dialogLaunchers.tsx",
    "src/history.ts",
    "src/ink.ts",
    "src/interactiveHelpers.tsx",
    "src/projectOnboardingState.ts",
    "src/query.ts",
    "src/replLauncher.tsx",
    "src/setup.ts",
    "src/tasks.ts",
    "src/tools.ts",
    "src/gateway/**/*"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "src/agent/**/*",
    "src/assistant/**/*",
    "src/bootstrap/**/*",
    "src/bridge/**/*",
    "src/buddy/**/*",
    "src/cli/**/*",
    "src/commands/**/*",
    "src/components/**/*",
    "src/constants/**/*",
    "src/context/**/*",
    "src/coordinator/**/*",
    "src/entrypoints/**/*",
    "src/hooks/**/*",
    "src/ink/**/*",
    "src/keybindings/**/*",
    "src/memdir/**/*",
    "src/migrations/**/*",
    "src/moreright/**/*",
    "src/native-ts/**/*",
    "src/outputStyles/**/*",
    "src/plugins/**/*",
    "src/query/**/*",
    "src/remote/**/*",
    "src/schemas/**/*",
    "src/screens/**/*",
    "src/server/**/*",
    "src/services/**/*",
    "src/skills/**/*",
    "src/state/**/*",
    "src/tasks/**/*",
    "src/tools/**/*",
    "src/types/**/*",
    "src/upstreamproxy/**/*",
    "src/utils/**/*",
    "src/vim/**/*",
    "src/voice/**/*"
  ]
}
